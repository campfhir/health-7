{
  "name": "@nems.org/hl7",
  "version": "1.0.0",
  "description": "TypeScript library for building HL7v2 messages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "convert": "node excel-to-hl7/dist/index.js convert",
    "verify": "node excel-to-hl7/dist/index.js verify",
    "codegen": "tsx codegen/generate.ts"
  },
  "keywords": [
    "hl7",
    "hl7v2",
    "healthcare",
    "message-builder"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "jose": "^6.1.3"
  }
}
